# Supabase bulut modu (opsiyonel)
# Bu değerler tanımlıysa uygulama gerçek bulut girişi + cihazlar arası
# ilerleme senkronu kullanır. Tanımlı değilse YEREL modda çalışır.
#
# Yerelde: bu dosyayı ".env" olarak kopyalayın.
# Production (GitHub Pages): repo → Settings → Secrets → Actions

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Premium ses — ElevenLabs TTS (günlük ~8000 karakter kota)
# https://elevenlabs.io/ → Profile → API Key
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# AI bonus diyalog — Work modu simülatör (gpt-4o-mini, günde 20 mesaj)
# https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# GitHub Actions Secrets (deploy.yml) — aynı isimlerle ekleyin:
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
#   VITE_ELEVENLABS_API_KEY, VITE_ELEVENLABS_VOICE_ID
#   VITE_OPENAI_API_KEY
